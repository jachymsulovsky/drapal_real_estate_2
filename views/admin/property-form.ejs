<%- include('../partials/admin-head') %>
<%- include('../partials/admin-nav') %>
<section class="admin-header">
  <div>
    <p class="eyebrow">Nemovitosti</p>
    <h1><%= title %></h1>
  </div>
  <a class="button secondary" href="/admin/properties">Zpět</a>
</section>

<% if (errors.length) { %><div class="flash error"><%= errors.join(' ') %></div><% } %>

<form class="admin-form" method="post" action="<%= action %>" enctype="multipart/form-data">
  <div class="form-grid">
    <label>Název<input name="title" value="<%= property.title || '' %>" required></label>
    <label>Slug URL<input name="slug" value="<%= property.slug || '' %>" placeholder="automaticky z názvu"></label>
    <label>Cena<input type="number" name="price" value="<%= property.price || '' %>" required></label>
    <label>Lokalita<input name="location" value="<%= property.location || '' %>" required></label>
    <label>Typ<input name="type" value="<%= property.type || '' %>" required></label>
    <label>Status
      <select name="status" required>
        <% ['Na prodej', 'Prodáno', 'Rezervováno'].forEach((status) => { %>
          <option value="<%= status %>" <%= property.status === status ? 'selected' : '' %>><%= status %></option>
        <% }) %>
      </select>
    </label>
    <label>Příslušenství<input name="accessories" value="<%= property.accessories || '' %>"></label>
    <label>Energetická náročnost<input name="energy_rating" value="<%= property.energy_rating || '' %>"></label>
    <label>Stavba<input name="construction" value="<%= property.construction || '' %>"></label>
    <label>Infrastruktura<input name="infrastructure" value="<%= property.infrastructure || '' %>"></label>
    <label>Plocha<input name="area" value="<%= property.area || '' %>"></label>
    <label>Vlastnictví<input name="ownership" value="<%= property.ownership || '' %>"></label>
    <label>Ostatní<input name="other" value="<%= property.other || '' %>"></label>
    <label>Historie<input name="history" value="<%= property.history || '' %>"></label>
    <label>Adresa<input name="address" value="<%= property.address || '' %>" required></label>
    <label>GPS lat<input type="number" step="0.000001" name="lat" value="<%= property.lat || '' %>" required></label>
    <label>GPS lng<input type="number" step="0.000001" name="lng" value="<%= property.lng || '' %>" required></label>
    <label>Makléř
      <select name="agent_id" required>
        <% agents.forEach((agent) => { %>
          <option value="<%= agent.id %>" <%= Number(property.agent_id) === agent.id ? 'selected' : '' %>><%= agent.name %></option>
        <% }) %>
      </select>
    </label>
  </div>
  <label>Popis<textarea name="description" required><%= property.description || '' %></textarea></label>
  <label>Fotografie<input type="file" name="images" accept="image/*" multiple></label>

  <% if (property.images && property.images.length) { %>
    <div class="thumb-row">
      <% property.images.forEach((image) => { %>
        <img src="<%= image.image_url %>" alt="<%= image.alt %>">
      <% }) %>
    </div>
  <% } %>

  <button class="button" type="submit">Uložit</button>
</form>
<%- include('../partials/admin-foot') %>
